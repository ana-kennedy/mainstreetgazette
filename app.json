{
  "expo": {
    "name": "Main Street Gazette",
    "slug": "main-street-gazette",
    "version": "2026.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "mainstreetgazette",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mainstreetgazette.app",
      "buildNumber": "12",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mainstreetgazette.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-background.png"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-audio",
      "expo-font",
      "expo-web-browser",
      "expo-task-manager",
      "expo-background-task",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "933b6f48-6c87-468e-a159-0c790e5cec5c"
      }
    },
    "owner": "anakennedy"
  }
}
